    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@supabase/supabase-js": "^2.57.4",
    "@types/markdown-it": "^14.1.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.65.1",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
