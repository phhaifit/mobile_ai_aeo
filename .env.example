# Jarvis AEO Environment Configuration
# Copy this file to .env.dev, .env.staging, or .env.prod

# API Configuration
API_BASE_URL=https://api.aeo.how
# AI assistant (Dio aiDioClient). Android emulator → host machine: http://10.0.2.2:PORT (not localhost).
# iOS simulator / desktop / web: http://localhost:PORT — physical device: your PC LAN IP.
AI_API_BASE_URL=http://localhost:8000

# Optional (debug builds): JWT sent as Bearer; overrides saved login when non-empty.
# ACCESS_TOKEN=

# Analytics
ANALYTICS_ENABLED=false

# Error Tracking (Sentry)
SENTRY_DSN=

# Environment: dev, staging, prod
ENVIRONMENT=dev

# Use this account to test article management feature
# email: john.doe@example.com
# password: StrongP@ss123
