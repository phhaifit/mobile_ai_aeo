  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main",
    "start:analyze": "cross-env WORKER_TYPE=projectAnalysis node dist/worker",
    "start:project": "cross-env WORKER_TYPE=createProject node dist/worker",
    "start:content": "cross-env WORKER_TYPE=contentGeneration node dist/worker",
    "start:social": "cross-env WORKER_TYPE=socialPublish node dist/worker",
    "start:dev": "nest start --watch",
    "start:analyze:dev": "cross-env WORKER_TYPE=projectAnalysis nest start --watch --entryFile worker",
    "start:project:dev": "cross-env WORKER_TYPE=createProject nest start --watch --entryFile worker",
    "start:content:dev": "cross-env WORKER_TYPE=contentGeneration nest start --watch --entryFile worker",
    "start:social:dev": "cross-env WORKER_TYPE=socialPublish nest start --watch --entryFile worker",
    "start:debug": "nest start --debug --watch",
    "start:analyze:debug": "cross-env WORKER_TYPE=projectAnalysis nest start --debug --watch --entryFile worker",
    "start:project:debug": "cross-env WORKER_TYPE=createProject nest start --debug --watch --entryFile worker",
    "start:content:debug": "cross-env WORKER_TYPE=contentGeneration nest start --debug --watch --entryFile worker",
    "start:social:debug": "cross-env WORKER_TYPE=socialPublish nest start --debug --watch --entryFile worker",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "check:lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "check:format": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "check:types": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "gen:types": "supabase gen types typescript --project-id lxlmwpkekpkrocxzxvyl > src/supabase/supabase.types.ts",
    "migrate:up": "supabase migration up --db-url ${SUPABASE_DB_URL}",
    "create:migration": "supabase migration new [function-name]"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.983.0",
